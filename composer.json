{
  "name": "philharmony/http-factory",
  "description": "PSR-17 HTTP factory implementation for Philharmony",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "psr-17",
    "http",
    "factory",
    "philharmony"
  ],
  "homepage": "https://github.com/philharmonytech/http-factory",
  "authors": [
    {
      "name": "Vyacheslav86RUS",
      "email": "ProSlavon86@gmail.com"
    }
  ],
  "require": {
    "php": "^8.1",
    "psr/http-factory": "^1.1",
    "psr/http-message": "^2.0",
    "philharmony/http-psr-extension": "^1.0",
    "philharmony/http-enum": "^1.3",
    "philharmony/http-message": "^1.4"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "phpstan/phpstan": "^1.0",
    "friendsofphp/php-cs-fixer": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "Philharmony\\Http\\Factory\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Philharmony\\Http\\Factory\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "test:coverage": "phpunit --coverage-clover coverage.xml --coverage-html coverage --coverage-filter src",
    "phpstan": "phpstan analyse --memory-limit=1G",
    "cs-check": "php-cs-fixer fix --dry-run --allow-risky=yes",
    "cs-fix": "php-cs-fixer fix --allow-risky=yes"
  },
  "config": {
    "sort-packages": true
  }
}
